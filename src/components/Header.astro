---
import Hamburger from './Hamburger.astro';
import Navigation from './Navigation.astro';
import ThemeIcon from './ThemeIcon.astro';
---
<header>
 <nav class="flex relative h-24">
   <div class="flex items-center flex-wrap">
      <div class="flex m-0 p-0 list-none divide-x-2 divide-black">
         <a href="https://opensensemap.org" class="flex items-center justify-center uppercase pr-4 pl-4">
            <img src="/logo.png" alt="openSenseMap brand logo" class="h-12">
         </a>
         <a href="/" class="flex items-center justify-center pr-4 pl-4">
            Blog
         </a>
      </div>
   </div>
   <div class="flex items-center ml-auto">
      <Hamburger />
      <Navigation />
      <ThemeIcon />
   </div>
 </nav>
</header>